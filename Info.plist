<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.micmute.app</string>

    <key>CFBundleName</key>
    <string>MicMute</string>

    <key>CFBundleDisplayName</key>
    <string>MicMute</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <key>CFBundleExecutable</key>
    <string>MicMute</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- Hide from Dock & app switcher -->
    <key>LSUIElement</key>
    <true/>

    <!-- Suppress terminal window on double-click -->
    <key>LSBackgroundOnly</key>
    <false/>

    <key>NSHighResolutionCapable</key>
    <true/>

    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- Microphone usage description (for TCC prompt) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>MicMute controls the microphone mute state.</string>
</dict>
</plist>
